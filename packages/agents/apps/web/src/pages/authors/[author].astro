---
import { getCollection } from 'astro:content';
import { getAuthorSlug } from '../../lib/articles';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => data.published);
  const authors = [...new Set(articles.map((article) => article.data.author))];

  return authors.map((author) => ({
    params: { author: getAuthorSlug(author) },
    props: {
      author,
      articles: articles.filter((article) => article.data.author === author)
    }
  }));
}

const { author, articles } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{author}</title>
  </head>
  <body>
    <main>
      <h1>{author}</h1>
      <ul>
        {articles.map((article) => (
          <li>
            <a href={`/articles/${article.data.slug}/`}>{article.data.title}</a>
          </li>
        ))}
      </ul>
    </main>
  </body>
</html>
