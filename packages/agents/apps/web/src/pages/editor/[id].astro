---
import PublishingEditor from '../../components/editor/PublishingEditor.jsx';

const { id } = Astro.params;
const response = await fetch(`${Astro.url.origin}/api/content/${encodeURIComponent(id)}`);
const work = response.ok ? await response.json() : null;
---

<html lang="en">
  <head>
    <title>Edit {work?.schema?.headline || 'CreativeWork'}</title>
  </head>
  <body>
    <main>
      <header>
        <h1>Edit CreativeWork</h1>
        <p>Update structured content, editor state, metadata, and workflow.</p>
      </header>

      {
        !work && (
          <section>
            <h2>Content not found</h2>
            <a href="/content">Back to content</a>
          </section>
        )
      }

      {
        work && (
          <section>
            <PublishingEditor
              id={work.id}
              creativeWorkType={work.creativeWorkType || work.schema?.['@type'] || 'CreativeWork'}
              initialRecord={work}
              client:load
            />
          </section>
        )
      }
    </main>
  </body>
</html>
